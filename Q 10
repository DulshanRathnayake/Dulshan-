import cv2 as cv
import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import RANSACRegressor
from google.colab import files

print("Please upload your screenshot:")
uploaded = files.upload()
filename = next(iter(uploaded)) 

# 1. Read the screenshot
img = cv.imread(filename, cv.IMREAD_GRAYSCALE)

# --- THE REFINED SCREENSHOT RESCUE ---
# Step A: Blur the image slightly to erase screenshot JPEG noise
img_blur = cv.GaussianBlur(img, (5, 5), 0)

# Step B: Boost contrast to hit the assignment's strict 550/690 requirement
img_ready = cv.convertScaleAbs(img_blur, alpha=2.2, beta=0)

# 2. Apply Canny Edge Detection
edges = cv.Canny(img_ready, 550, 690)

# 3. Extract coordinates
indices = np.where(edges != 0)
x = indices[1]
y = indices[0]

# Failsafe check
print(f"Extracted {len(x)} clean edge points.")
if len(x) < 20:
    print("WARNING: Still not enough points. The screenshot might be too low resolution.")

# 4. Reshape x and fit RANSAC
x_reshaped = x.reshape(-1, 1)
ransac = RANSACRegressor(random_state=42) 
ransac.fit(x_reshaped, y)

y_ransac = ransac.predict(x_reshaped)

# 5. Plotting
plt.figure(figsize=(8, 4))

# Subplot 1: Show the cleaned-up Canny Edges
plt.subplot(1, 2, 1)
plt.imshow(edges, cmap='gray')
plt.title("Refined Canny Edges")
plt.axis('off')

# Subplot 2: Show the RANSAC Fit
ax = plt.subplot(1, 2, 2)
ax.scatter(x, y, s=2, color='teal', alpha=0.6, label='Edges')
ax.plot(x, y_ransac, color='crimson', linewidth=2, label="RANSAC Line")
ax.invert_yaxis()
ax.legend()
plt.title("RANSAC Fit")

plt.tight_layout()
plt.show()

# 6. Calculate Angle
slope_ransac = ransac.estimator_.coef_[0]
angle_ransac = np.degrees(np.arctan(slope_ransac))

print(f"RANSAC Estimated Angle: {angle_ransac:.2f} degrees")
